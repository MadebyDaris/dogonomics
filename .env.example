# Polygon.io API Configuration
# Get key at: https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API Configuration
# Get key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API Configuration (for commodities)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# EODHD API Configuration (for financial news)
# Get key at: https://eodhd.com
EODHD_API_KEY=your_eodhd_api_key_here

# GNews API Configuration
# Get key at: https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# Firebase Admin SDK (backend auth verification)
# Preferred: absolute or relative path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
# Alternative: raw JSON content (single-line escaped JSON)
# In Docker, this is usually the easiest option unless you also mount the file path.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Legacy compatibility alias (same value as FIREBASE_SERVICE_ACCOUNT_PATH)
FIREBASE_CREDENTIALS=

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dogonomics
DB_PASSWORD=dogonomics_password
DB_NAME=dogonomics
DB_SSLMODE=disable

# Docker Configuration
# When running in Docker, use:
# DB_HOST=timescaledb

# Application Configuration
GIN_MODE=release
PORT=8080

# Optional ONNX Runtime shared library path for local ONNX builds
# Linux example: ONNX_RUNTIME_LIB_PATH=/usr/lib64/libonnxruntime.so.1
# Windows example: ONNX_RUNTIME_LIB_PATH=C:/onnxruntime/lib/onnxruntime.dll
# ONNX_RUNTIME_LIB_PATH=

# API Access Control
# Set to true in production to require a valid API key on every API call.
API_KEY_REQUIRED=true
# Comma-separated allowlist of accepted API keys.
API_ALLOWED_KEYS=
# Optional single-key alias (kept for compatibility). Leave blank when using API_ALLOWED_KEYS.
API_KEY=

# Rate Limiting (requests/min)
# RATE_LIMIT_RPM is the global fallback if subject-specific limits are not set.
RATE_LIMIT_RPM=100
# Stricter layered limits by identity type.
RATE_LIMIT_RPM_IP=60
RATE_LIMIT_RPM_KEY=120
RATE_LIMIT_RPM_USER=90

# FinBERT Inference Protection
# Keep this at 1 to force one-at-a-time inference globally.
BERT_MAX_CONCURRENCY=1
# Max seconds a request will wait for the FinBERT queue before failing.
BERT_QUEUE_TIMEOUT_SECONDS=65

# FinBERT Model Assets
# Paths used by backend at startup (can be local files or mounted files)
BERT_MODEL_PATH=./sentAnalysis/DoggoFinBERT.onnx
BERT_VOCAB_PATH=./sentAnalysis/finbert/vocab.txt
# If true, backend will attempt to download missing model/vocab on startup.
BERT_AUTO_DOWNLOAD=true
# Provide URLs if you want startup auto-download on cloud instances.
# Example (replace with your own hosted assets):
# BERT_MODEL_URL=https://your-bucket.example.com/DoggoFinBERT.onnx
# BERT_VOCAB_URL=https://your-bucket.example.com/vocab.txt
# Note: Google Drive share links are unreliable for large files in automated
# startup flows due confirmation/cookie pages. Prefer direct object-storage URLs.
BERT_MODEL_URL=
BERT_VOCAB_URL=

# MCP Configuration
# Enable Model Context Protocol server
MCP_ENABLED=true
# Address to bind MCP SSE server
MCP_ADDR=:8081
# Base URL for MCP SSE endpoints
MCP_BASE_URL=http://localhost:8081

# Optional AI sidecar deployment (docker compose --profile ai)
# Ollama host port mapping
OLLAMA_PORT=11434
# Model for the MCP client bridge sidecar
OLLAMA_MODEL=llama3
# Optional override for MCP endpoint consumed by mcp-client service
MCP_CLIENT_SERVER_URL=http://dogonomics:8081/mcp/sse
# Heartbeat interval for mcp-client sidecar
MCP_CLIENT_KEEPALIVE_SECONDS=30
# Reconnect delay when MCP connection drops
MCP_RETRY_DELAY_SECONDS=5

# Economic Data Configuration (FRED)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
