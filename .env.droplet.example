# Copy this to .env on your DigitalOcean Droplet and fill in secrets.
# Keep this file out of git if you add real credentials.

POLYGON_API_KEY=
FINNHUB_API_KEY=
EODHD_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
GNEWS_API_KEY=

DB_PORT=5432
DB_USER=dogonomics
DB_PASSWORD=dogonomics_password
DB_NAME=dogonomics
DB_SSLMODE=disable

GIN_MODE=release
PORT=8080
MCP_PORT=8081

# Firebase inside container
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-adminsdk.json
# Firebase on Droplet host
FIREBASE_SERVICE_ACCOUNT_HOST_PATH=/mnt/dogonomics/secrets/firebase-adminsdk.json

MCP_ENABLED=true
MCP_ADDR=:8081
# Set this to your public Droplet URL or IP so external MCP clients can connect.
MCP_BASE_URL=http://YOUR_DROPLET_IP:8081
# Internal target for the MCP bridge sidecar in docker-compose.
MCP_CLIENT_SERVER_URL=http://dogonomics:8081/mcp/sse

RATE_LIMIT_RPM=100
RATE_LIMIT_RPM_IP=60
RATE_LIMIT_RPM_KEY=120
RATE_LIMIT_RPM_USER=90

BERT_MAX_CONCURRENCY=1
BERT_QUEUE_TIMEOUT_SECONDS=65

API_KEY_REQUIRED=true
API_ALLOWED_KEYS=dogonomics_frontend_static_key_2026
API_KEY=

# Persistent host data root for bind mounts
DOGONOMICS_DATA_ROOT=/mnt/dogonomics

# Optional AI profile defaults
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3
MCP_CLIENT_KEEPALIVE_SECONDS=30
MCP_RETRY_DELAY_SECONDS=5
