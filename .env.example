# Polygon.io API Configuration
# Get key at: https://polygon.io
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API Configuration
# Get key at: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API Configuration (for commodities)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# EODHD API Configuration (for financial news)
# Get key at: https://eodhd.com
EODHD_API_KEY=your_eodhd_api_key_here

# GNews API Configuration
# Get key at: https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# Firebase Admin SDK (backend auth verification)
# Preferred: absolute or relative path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=
# Alternative: raw JSON content (single-line escaped JSON)
# In Docker, this is usually the easiest option unless you also mount the file path.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Legacy compatibility alias (same value as FIREBASE_SERVICE_ACCOUNT_PATH)
FIREBASE_CREDENTIALS=

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dogonomics
DB_PASSWORD=dogonomics_password
DB_NAME=dogonomics
DB_SSLMODE=disable

# Docker Configuration
# When running in Docker, use:
# DB_HOST=timescaledb

# Application Configuration
GIN_MODE=release
PORT=8080
